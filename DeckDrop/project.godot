; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="DeckDrop"
config/description="Tap a column to drop a card. Make poker hands across rows and columns. Endless."
run/main_scene="res://scenes/Title.tscn"
config/features=PackedStringArray("4.6", "Mobile")
config/icon="res://icon_app.svg"
# Version metadata — bump version/string + version/code for every Play release.
# version/code must increase on every Play upload (it's how Play orders
# upgrades). version/string is the human-facing label shown in the listing.
config/version="1.0.0"
config/version_code=1

[autoload]

SaveData="*res://scripts/save_data.gd"
Sfx="*res://scripts/sfx.gd"
MatchState="*res://scripts/match_state.gd"
FontLoader="*res://scripts/font_loader.gd"

[display]

window/size/viewport_width=1080
window/size/viewport_height=1920
window/size/window_width_override=720
window/size/window_height_override=1280
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation="portrait"

[gui]

theme/custom="res://themes/main_theme.tres"

[input_devices]

pointing/emulate_touch_from_mouse=true

[rendering]

renderer/rendering_method="mobile"
